MONGO_URL=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/?appName=Cluster0
DB_NAME=midnightrotation
GEMINI_API_KEY=your-gemini-api-key-here
PRINTIFY_API_TOKEN=your-printify-token-here

# Required: strong random secret used to protect mutating endpoints.
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_API_KEY=replace-with-a-strong-random-secret

# Required: comma-separated list of allowed CORS origins. No wildcards.
# Example: https://yourapp.vercel.app,http://localhost:5173
CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173
